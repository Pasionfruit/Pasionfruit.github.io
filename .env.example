# Google Sheets API (for public reads)
VITE_SHEETS_SPREADSHEET_ID=REPLACE_WITH_YOUR_SPREADSHEET_ID
VITE_SHEETS_API_KEY=REPLACE_WITH_YOUR_GOOGLE_SHEETS_API_KEY

# Google OAuth (for admin sign-in and writes)
VITE_GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# Apps Script (for authenticated writes only)
VITE_SHEETS_API_BASE_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT/exec

# Todoist API (for Home tasks of the day)
VITE_TODOIST_API_TOKEN=REPLACE_WITH_YOUR_TODOIST_API_TOKEN

# Gaming / Minecraft — Aternos (current)
#   NTFY_TOPIC  → Apps Script Script Properties (push notification topic for server start requests)

# Gaming / Minecraft — Self-hosted (future — fill these in when you switch)
# Public URL from Cloudflare Tunnel (run scripts/gaming/start_local.bat to get it)
VITE_MC_LOCAL_API=
# Must match MC_API_TOKEN in scripts/gaming/mc_server.env
VITE_MC_API_TOKEN=
# Your server address shown to players (home IP:port, playit.gg address, or DynDNS hostname)
# Leave MC_SERVER_ADDR in App.tsx as-is until you know this