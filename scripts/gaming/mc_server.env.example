# ── Minecraft server path ────────────────────────────────────────────────────
# Full path to your server.jar
MC_JAR_PATH=C:/minecraft/server.jar

# Path to the world folder (optional — defaults to <jar_dir>/world)
# MC_WORLD_PATH=C:/minecraft/world

# JVM memory flags — adjust to your machine's RAM
MC_JVM_ARGS=-Xmx4G -Xms2G

# ── Networking ───────────────────────────────────────────────────────────────
# Minecraft game port (players connect here — needs port forwarding or playit.gg)
MC_PORT=25565

# Port this API server listens on (internal only — exposed via Cloudflare Tunnel)
API_PORT=8080

# ── Security ─────────────────────────────────────────────────────────────────
# Random secret — copy this exact value into your GitHub repo .env as VITE_MC_API_TOKEN
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
MC_API_TOKEN=REPLACE_WITH_A_RANDOM_SECRET
