# Path to the Google service account JSON key file.
# Create one at: Google Cloud Console → APIs & Services → Credentials → Service Accounts
# Then share your spreadsheet with the service account email address.
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json

# Exact name of your Google Spreadsheet (as it appears in Google Drive)
SPREADSHEET_NAME=Your Spreadsheet Name

# Garmin Connect credentials (required for --api mode only)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword
